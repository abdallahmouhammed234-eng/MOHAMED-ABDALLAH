  .checkout-btn {
    width: 100%; padding: 15px; background: var(--espresso); color: var(--gold);
    border: none; font-family: 'Jost'; font-size: 0.72rem; font-weight: 500;
    letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer; transition: all 0.3s;
  }
  .checkout-btn:hover { background: var(--gold); color: var(--espresso); }

